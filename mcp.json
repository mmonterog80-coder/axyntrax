{
    "mcpServers":  {
                       "sequential-thinking":  {
                                                   "command":  "npx",
                                                   "args":  [
                                                                "-y",
                                                                "@modelcontextprotocol/server-sequential-thinking"
                                                            ]
                                               },
                       "memory":  {
                                      "command":  "npx",
                                      "args":  [
                                                   "-y",
                                                   "@modelcontextprotocol/server-memory"
                                               ]
                                  },
                       "fetch":  {
                                     "command":  "uvx",
                                     "args":  [
                                                  "mcp-server-fetch",
                                                  "--ignore-robots-txt"
                                              ]
                                 },
                       "time":  {
                                    "command":  "uvx",
                                    "args":  [
                                                 "mcp-server-time"
                                             ]
                                },
                       "filesystem":  {
                                          "command":  "npx",
                                          "args":  [
                                                       "-y",
                                                       "@modelcontextprotocol/server-filesystem",
                                                       "C:\\AXYNTRAX"
                                                   ]
                                      },
                       "git":  {
                                   "command":  "uvx",
                                   "args":  [
                                                "mcp-server-git",
                                                "-r",
                                                "C:\\AXYNTRAX"
                                            ]
                               },
                       "github":  {
                                      "command":  "npx",
                                      "args":  [
                                                   "-y",
                                                   "@modelcontextprotocol/server-github"
                                               ],
                                      "env":  {
                                                  "GITHUB_PERSONAL_ACCESS_TOKEN":  ""
                                              }
                                  },
                       "postgres":  {
                                        "command":  "npx",
                                        "args":  [
                                                     "-y",
                                                     "@modelcontextprotocol/server-postgres",
                                                     "postgresql://user:pass@localhost:5432/axyntrax"
                                                 ]
                                    },
                       "openapi-gateway":  {
                                               "command":  "npx",
                                               "args":  [
                                                            "-y",
                                                            "@modelcontextprotocol/server-openapi"
                                                        ]
                                           },
                       "browser":  {
                                       "command":  "npx",
                                       "args":  [
                                                    "-y",
                                                    "@modelcontextprotocol/server-puppeteer"
                                                ]
                                   },
                       "search":  {
                                      "command":  "npx",
                                      "args":  [
                                                   "-y",
                                                   "@modelcontextprotocol/server-brave-search"
                                               ],
                                      "env":  {
                                                  "BRAVE_API_KEY":  ""
                                              }
                                  },
                       "slack":  {
                                     "command":  "npx",
                                     "args":  [
                                                  "-y",
                                                  "@modelcontextprotocol/server-slack"
                                              ],
                                     "env":  {
                                                 "SLACK_BOT_TOKEN":  ""
                                             }
                                 },
                       "stripe":  {
                                      "command":  "npx",
                                      "args":  [
                                                   "-y",
                                                   "@modelcontextprotocol/server-stripe"
                                               ],
                                      "env":  {
                                                  "STRIPE_SECRET_KEY":  ""
                                              }
                                  },
                       "crm":  {
                                   "command":  "npx",
                                   "args":  [
                                                "-y",
                                                "@modelcontextprotocol/server-hubspot"
                                            ],
                                   "env":  {
                                               "HUBSPOT_TOKEN":  ""
                                           }
                               },
                       "doc-processing":  {
                                              "command":  "uvx",
                                              "args":  [
                                                           "mcp-server-pdf"
                                                       ]
                                          },
                       "vector-rag":  {
                                          "command":  "uvx",
                                          "args":  [
                                                       "mcp-server-chroma"
                                                   ]
                                      },
                       "security-scan":  {
                                             "command":  "npx",
                                             "args":  [
                                                          "-y",
                                                          "@modelcontextprotocol/server-semgrep"
                                                      ]
                                         },
                       "observability":  {
                                             "command":  "npx",
                                             "args":  [
                                                          "-y",
                                                          "@modelcontextprotocol/server-datadog"
                                                      ],
                                             "env":  {
                                                         "DD_API_KEY":  ""
                                                     }
                                         },
                       "scheduler":  {
                                         "command":  "npx",
                                         "args":  [
                                                      "-y",
                                                      "@modelcontextprotocol/server-cron"
                                                  ]
                                     },
                       "model-router":  {
                                            "command":  "uvx",
                                            "args":  [
                                                         "mcp-server-litellm"
                                                     ]
                                        },
                       "backup":  {
                                      "command":  "npx",
                                      "args":  [
                                                   "-y",
                                                   "@modelcontextprotocol/server-aws-s3"
                                               ],
                                      "env":  {
                                                  "AWS_ACCESS_KEY_ID":  ""
                                              }
                                  },
                       "vault":  {
                                     "command":  "uvx",
                                     "args":  [
                                                  "mcp-server-hashicorp-vault"
                                              ]
                                 },
                       "analytics":  {
                                         "command":  "npx",
                                         "args":  [
                                                      "-y",
                                                      "@modelcontextprotocol/server-posthog"
                                                  ],
                                         "env":  {
                                                     "POSTHOG_API_KEY":  ""
                                                 }
                                     },
                       "claude-eyes":  {
                                           "args":  [
                                                        "-y",
                                                        "claude-eyes"
                                                    ],
                                           "command":  "npx"
                                       },
                       "playwright-mcp":  {
                                              "args":  [
                                                           "-y",
                                                           "@modelcontextprotocol/server-playwright"
                                                       ],
                                              "command":  "npx"
                                          },
                       "sentry": {
                                     "command": "npx",
                                     "args": [
                                                 "-y",
                                                 "@modelcontextprotocol/server-sentry"
                                             ],
                                     "env": {
                                                "SENTRY_AUTH_TOKEN": ""
                                            }
                                 },
                       "redis": {
                                    "command": "npx",
                                    "args": [
                                                "-y",
                                                "@modelcontextprotocol/server-redis",
                                                "redis://localhost:6379"
                                            ]
                                }
                   }
}
