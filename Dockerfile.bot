# Bot de Telegram Audiovisual
FROM python:3.14-slim

WORKDIR /app

# Instalar dependencias del sistema para Playwright
RUN apt-get update && apt-get install -y \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    && rm -rf /var/lib/apt/lists/*

COPY telegram_bot.py .
COPY .env .

RUN pip install --no-cache-dir python-telegram-bot openai python-dotenv requests edge-tts playwright
RUN playwright install chromium

CMD ["python", "telegram_bot.py"]
